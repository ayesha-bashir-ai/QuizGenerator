# ============================================================
#  QuizGenius AI — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env — only commit this .env.example file.
# ============================================================


# ─── DATABASE (Neon PostgreSQL) ────────────────────────────
# Get this from neon.tech → your project → Connection Details
# Use the POOLED connection string (has "-pooler" in the URL)
# Example format:
# postgresql://username:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

DATABASE_URL=postgresql://your_user:your_password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require


# ─── OPENAI ────────────────────────────────────────────────
# Get this from platform.openai.com/api-keys
# Recommended model in ai.py: gpt-4o-mini (fast + affordable)

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── FLASK SECRET KEY ──────────────────────────────────────
# Used to sign session cookies and CSRF tokens.
# Use any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# On Render you can use their built-in "Generate" button instead.

SECRET_KEY=change-this-to-a-long-random-string-before-deploying


# ─── FILE UPLOAD ───────────────────────────────────────────
# Maximum allowed upload size in megabytes.
# Render free tier has limited memory so keep this at 10 or lower.

MAX_UPLOAD_MB=10


# ─── OPTIONAL / FUTURE ─────────────────────────────────────
# Uncomment and fill in if you add these features later:

# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-app-password

# REDIS_URL=redis://localhost:6379/0
