# ============================================================
#  QuizGenius AI — .gitignore
#  Place this file at the ROOT of your project (quiz-ai/)
# ============================================================


# ─── SECRET FILES — NEVER COMMIT THESE ────────────────────
.env
*.env
!.env.example


# ─── UPLOADED USER FILES ──────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep


# ─── PYTHON ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
dist/
build/
*.egg


# ─── DATABASE (local SQLite if used) ──────────────────────
*.db
*.sqlite
*.sqlite3


# ─── IDE & EDITOR ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
.DS_Store
Thumbs.db
desktop.ini


# ─── LOGS ─────────────────────────────────────────────────
*.log
logs/


# ─── NODE (if you ever add a build step) ──────────────────
node_modules/
npm-debug.log*


# ─── OS FILES ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db


# ─── PYTEST / TESTING ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/


# ─── MISC ─────────────────────────────────────────────────
*.pem
*.key
*.cert
tmp/
temp/